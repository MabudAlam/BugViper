# ── Unrelated services ───────────────────────────────────────────────────────
# Exclude ingestion_service/ except the language parsers (needed by review_service)
ingestion_service/
!ingestion_service/__init__.py
!ingestion_service/languages/
frontend/
node_modules/

# ── Dev / build artefacts ────────────────────────────────────────────────────
.venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage

# ── Secrets & credentials ────────────────────────────────────────────────────
.env
.env.*
*.pem
service.json

# ── Logs & runtime output ────────────────────────────────────────────────────
*.log
logs/
output/

# ── Docs, assets & repo metadata ─────────────────────────────────────────────
.git/
.github/
.claude/
docs/
screenshots/
README.md
CLAUDE.md
CYPHER_GUIDE.md
LICENSE

# ── CI / local tooling ───────────────────────────────────────────────────────
cloudbuild.*.yaml
start.sh
