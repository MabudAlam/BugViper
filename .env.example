# ============================================================================
# REQUIRED — GitHub App (bot identity: webhooks, repo cloning, PR comments)
# ============================================================================
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_MARKETPLACE_WEBHOOK_SECRET=

# ============================================================================
# REQUIRED — Firebase (service account JSON path or inline JSON)
# ============================================================================
SERVICE_FILE_LOC=

# ============================================================================
# LLM PROVIDERS (at least one required for the review agent)
# ============================================================================

# OpenRouter — single key for all models (required)
OPENROUTER_API_KEY=

# MiniMax — required when DEEPAGENT_MODEL starts with `MiniMax-`
MINIMAX_API_KEY=

# Gemini — required when DEEPAGENT_MODEL starts with `gemini/`
GEMINI_API_KEY=

# ============================================================================
# DEEPAGENT CODE REVIEW (sandboxed E2B agent — set when USE_DEEPAGENT_REVIEW=true)
# See: src/ncodereview/config.py
# DEEPAGENT_MODEL is the fallback for all roles.
# Set ORCHESTRATOR_MODEL / SUBAGENT_MODEL individually to use different models.
# JUDGE_MODEL is read directly in src/ncodereview/judge.py.
# ============================================================================
USE_DEEPAGENT_REVIEW=true
E2B_API_KEY=
DEEPAGENT_MODEL=deepseek/deepseek-v4-flash
ORCHESTRATOR_MODEL=
SUBAGENT_MODEL=
DEEPAGENT_SANDBOX_TIMEOUT=1800
DEEPAGENT_MAX_TOOL_ROUNDS=40
DEEPAGENT_REVIEW_MODE=normal
MAX_CONCURRENT_SANDBOXES=4
E2B_SANDBOX_TEMPLATE_SMALL=
E2B_SANDBOX_TEMPLATE_LARGE=

# DeepAgent judge settings (src/ncodereview/judge.py)
JUDGE_MODEL=deepseek/deepseek-v4-flash
JUDGE_READ_RADIUS=15
JUDGE_READ_MAX=60
NITPICK_CONFIDENCE_FLOOR=7

# DeepAgent dedup model (src/ncodereview/dedup.py)
DEDUP_MODEL=openai/gpt-4o-mini

# ============================================================================
# CORS — comma-separated list of allowed frontend origins (src/api/app.py)
# ============================================================================
API_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================================
# FRONTEND — Next.js public env vars (prefixed with NEXT_PUBLIC_)
# ============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=

# ============================================================================
# NEO4J (database — src/ ingestion layer)
# ============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# ============================================================================
# FIRESTORE / GCS (further Firebase configuration)
# ============================================================================
FIREBASE_STORAGE_BUCKET=bugviper-graphs.appspot.com

# ============================================================================
# LINT SERVICE — optional microservice for static analysis in reviews
# ============================================================================
LINT_SERVICE_URL=http://localhost:8090

# ============================================================================
# GOOGLE CLOUD TASKS — optional async ingestion/review dispatch
# Leave unset for local dev; API falls back to direct HTTP.
# ============================================================================
CLOUD_TASKS_QUEUE=ingestion-queue
CLOUD_TASKS_REVIEW_QUEUE=codeReview
INGESTION_SERVICE_URL=http://localhost:8080
REVIEW_SERVICE_URL=http://localhost:8100
CLOUD_TASKS_SA_EMAIL=
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# ============================================================================
# LANGCHAIN / LANGSMITH TRACING — optional
# ============================================================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=BugViper
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=BugViper

# ============================================================================
# PYDANTIC LOGFIRE — optional observability
# ============================================================================
ENABLE_LOGFIRE=false
LOGFIRE_TOKEN=

# ============================================================================
# NGROK — optional; use a reserved domain for stable webhook URL
# ============================================================================
NGROK_DOMAIN=
NGROK_URL=

# ============================================================================
# REPOSITORY CLONING — optional; defaults to system temp dir
# ============================================================================
CLONE_DIR=

# ============================================================================
# API AGENT (ReAct) — optional overrides
# ============================================================================
MODEL=openai/gpt-4o-mini
MAX_SEARCH_RESULTS=10
SYSTEM_PROMPT=

# ============================================================================
# PR DESCRIPTION — allow agent to update PR description with review summary
# ============================================================================
ENABLE_PR_DESCRIPTION_UPDATE=true

# ============================================================================
# GENERALIST AGENT — when true, uses single generalist instead of 3 specialists
# ============================================================================
USE_GENERALIST_SUBAGENT=true
